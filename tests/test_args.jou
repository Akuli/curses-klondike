import "stdlib/assert.jou"
import "stdlib/io.jou"
import "stdlib/process.jou"


def compile_parser_to_tests_temp_folder() -> None:
    chdir("tests")

    # Sanity check, we should now be in tests folder
    f = fopen("test_args.jou", "r")
    assert f != NULL
    fclose(f)

    # The main function of args.jou prints the parsed arguments. Let's compile that.
    ret = system("mkdir -p tmp && jou ../src/args.jou -o tmp/args")
    assert ret == 0


def test_help() -> None:
    # Output: Usage: tmp/args [--help] [--no-colors] [--pick n] [--discard-hide]
    # Output:
    # Output: Options:
    # Output:   --help          show this help message and exit
    # Output:   --no-colors     don't use colors, even if the terminal supports colors
    # Output:   --pick n        pick n cards from stock at a time, default is 3
    # Output:   --discard-hide  only show topmost discarded card (not useful with --pick=1)
    assert system("tmp/args --help") == 0


def test_defaults() -> None:
    # Output: Color: yes
    # Output: Pick: 3
    # Output: Discard hide: no
    system("tmp/args")


def test_no_defaults() -> None:
    # Output: Color: no
    # Output: Pick: 2
    # Output: Discard hide: yes
    assert system("tmp/args --no-color --pick=2 --discard-hide") == 0


def test_errors() -> None:
    # Output: tmp/args: unknown option '--wut'
    # Output: Run 'tmp/args --help' for help.
    assert system("tmp/args --wut") != 0

    # TODO: test ambiguous option if there will ever be an ambiguous option

    # Output: tmp/args: unexpected argument: 'wut'
    # Output: Run 'tmp/args --help' for help.
    assert system("tmp/args wut") != 0

    # Output: tmp/args: use just '--no-colors', not '--no-colors something' or '--no-colors=something'
    # Output: Run 'tmp/args --help' for help.
    assert system("tmp/args --no-colors lel") != 0

    # Output: tmp/args: use just '--no-colors', not '--no-colors something' or '--no-colors=something'
    # Output: Run 'tmp/args --help' for help.
    assert system("tmp/args --no-colors=lel") != 0

    # Output: tmp/args: repeated option '--no-colors'
    # Output: Run 'tmp/args --help' for help.
    assert system("tmp/args --no-colors --no-colors") != 0

    # Output: tmp/args: repeated option '--no-colors'
    # Output: Run 'tmp/args --help' for help.
    assert system("tmp/args --no-colors --no-colors --no-colors --no-colors") != 0

    # Output: tmp/args: use '--pick something' or '--pick=something', not just '--pick'
    # Output: Run 'tmp/args --help' for help.
    assert system("tmp/args --no-colors --pick") != 0

    # Output: tmp/args: '--pick' wants an integer between 1 and 24, not 'a'
    # Output: Run 'tmp/args --help' for help.
    assert system("tmp/args --pick a") != 0

    # Output: tmp/args: unexpected argument: '2'
    # Output: Run 'tmp/args --help' for help.
    assert system("tmp/args --pick 1 2") != 0

    # Output: tmp/args: '--pick' wants an integer between 1 and 24, not '0'
    # Output: Run 'tmp/args --help' for help.
    assert system("tmp/args --pick 0") != 0

    # Output: tmp/args: '--pick' wants an integer between 1 and 24, not '0'
    # Output: Run 'tmp/args --help' for help.
    assert system("tmp/args --pick=0") != 0

    # Output: Color: yes
    # Output: Pick: 1
    # Output: Discard hide: no
    assert system("tmp/args --pick=1") == 0


def test_nused_bug() -> None:
    # The bug was that --no-color got ignored.
    #
    # Output: Color: no
    # Output: Pick: 1
    # Output: Discard hide: no
    assert system("tmp/args --pick=1 --no-color") == 0


def main() -> int:
    compile_parser_to_tests_temp_folder()
    test_help()
    test_defaults()
    test_no_defaults()
    test_errors()
    test_nused_bug()
    return 0
